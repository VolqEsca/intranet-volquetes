# CORS para employees (copiado de manufacturing-orders)
Header always set Access-Control-Allow-Origin "https://intranet.volquetesescalante.com"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
Header always set Access-Control-Allow-Credentials "true"

# Permitir también webcontainer.io para StackBlitz
SetEnvIf Origin "^https://.*\.webcontainer\.io$" ORIGIN_ALLOWED=$0
Header always set Access-Control-Allow-Origin %{ORIGIN_ALLOWED}e env=ORIGIN_ALLOWED

# Handle preflight OPTIONS requests
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]
